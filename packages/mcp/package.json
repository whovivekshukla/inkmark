{
  "name": "@inkmark/mcp",
  "version": "0.1.0",
  "description": "MCP server for Inkmark — clip URLs, save highlights, and search your reading library from Claude and other AI hosts.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "inkmark",
    "claude",
    "bookmarks",
    "reading",
    "highlights"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whovivekshukla/inkmark.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "inkmark-mcp": "./dist/index.js",
    "inkmark-mcp-http": "./dist/http.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start:http": "node dist/http.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@inkmark/shared": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "*"
  }
}
