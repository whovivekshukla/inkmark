{
  "info": {
    "name": "Inkmark API",
    "description": "Inkmark — social reading app. Clip articles, highlight text, follow others.\n\n## Authentication\nAll protected endpoints require a Bearer token in the `Authorization` header. Obtain a token by completing the Google OAuth flow at `GET /api/v1/auth/google`.\n\n## Response Format\nAll responses use the `ApiResponse<T>` envelope:\n- **Success**: `{ success: true, data: T, meta?: PaginationMeta }`\n- **Error**: `{ success: false, error: { code: string, message: string } }`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "clipId",
      "value": "",
      "type": "string"
    },
    {
      "key": "highlightId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tagId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Google OAuth 2.0 authentication and user session management.",
      "item": [
        {
          "name": "Google OAuth — Initiate Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            },
            "description": "Redirects to Google OAuth consent screen. After the user grants access, Google redirects back to the callback URL which issues a JWT token.\n\n**Open this URL in a browser** — it initiates a redirect flow, not a JSON response."
          },
          "response": []
        },
        {
          "name": "Google OAuth — Callback",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google/callback?code=GOOGLE_AUTH_CODE",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "callback"],
              "query": [
                {
                  "key": "code",
                  "value": "GOOGLE_AUTH_CODE",
                  "description": "Authorization code from Google (set automatically by the OAuth flow)"
                }
              ]
            },
            "description": "Handles the OAuth callback from Google. Upserts the user and redirects to `CLIENT_REDIRECT_URL?token=<JWT>`.\n\n**Do not call this manually** — it's handled by the OAuth redirect flow."
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the authenticated user's profile."
          },
          "response": [
            {
              "name": "200 — Success",
              "originalRequest": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/auth/me",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "me"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"clx1abc123def456\",\n    \"username\": \"vivek_42\",\n    \"email\": \"vivek@example.com\",\n    \"displayName\": \"Vivek Shukla\",\n    \"avatarUrl\": \"https://lh3.googleusercontent.com/a/photo\",\n    \"bio\": null,\n    \"createdAt\": \"2025-01-15T10:30:00.000Z\"\n  }\n}"
            },
            {
              "name": "401 — Unauthorized",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/auth/me",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "me"]
                }
              },
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"AUTH_TOKEN_MISSING\",\n    \"message\": \"Authorization header is required\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Stateless logout — the server returns 204 and the client should drop the stored token."
          },
          "response": [
            {
              "name": "204 — No Content",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/auth/logout",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "logout"]
                }
              },
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Clips",
      "description": "CRUD for clips (saved articles/URLs). Includes tag management and nested highlights.",
      "item": [
        {
          "name": "Create Clip",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('clipId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/article\",\n  \"title\": \"Interesting Article\",\n  \"description\": \"A deep dive into something fascinating\",\n  \"ogImage\": \"https://example.com/og-image.jpg\",\n  \"faviconUrl\": \"https://example.com/favicon.ico\",\n  \"isPublic\": true,\n  \"tags\": [\"reading\", \"tech\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clips",
              "host": ["{{baseUrl}}"],
              "path": ["clips"]
            },
            "description": "Creates a new clip. The `clipId` collection variable is auto-set from the response.\n\n**Required**: `url` (valid URL)\n**Optional**: `title`, `description`, `ogImage`, `faviconUrl`, `isPublic` (default: true), `tags` (array of tag names)"
          },
          "response": [
            {
              "name": "201 — Created",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"url\": \"https://example.com/article\",\n  \"title\": \"Interesting Article\",\n  \"description\": \"A deep dive into something fascinating\",\n  \"isPublic\": true,\n  \"tags\": [\"reading\", \"tech\"]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/clips",
                  "host": ["{{baseUrl}}"],
                  "path": ["clips"]
                }
              },
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"clx1clip1234abcd\",\n    \"userId\": \"clx1abc123def456\",\n    \"url\": \"https://example.com/article\",\n    \"domain\": \"example.com\",\n    \"title\": \"Interesting Article\",\n    \"description\": \"A deep dive into something fascinating\",\n    \"ogImage\": null,\n    \"faviconUrl\": null,\n    \"isPublic\": true,\n    \"savedAt\": \"2025-01-15T12:00:00.000Z\",\n    \"updatedAt\": \"2025-01-15T12:00:00.000Z\",\n    \"tags\": [\n      {\n        \"clipId\": \"clx1clip1234abcd\",\n        \"tagId\": \"clx1tag001\",\n        \"tag\": { \"id\": \"clx1tag001\", \"name\": \"reading\" }\n      },\n      {\n        \"clipId\": \"clx1clip1234abcd\",\n        \"tagId\": \"clx1tag002\",\n        \"tag\": { \"id\": \"clx1tag002\", \"name\": \"tech\" }\n      }\n    ]\n  }\n}"
            },
            {
              "name": "400 — Validation Error",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"url\": \"not-a-valid-url\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/clips",
                  "host": ["{{baseUrl}}"],
                  "path": ["clips"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"VALIDATION_ERROR\",\n    \"message\": \"Invalid url\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List Clips",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clips?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["clips"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (default: 1)" },
                { "key": "limit", "value": "20", "description": "Items per page (default: 20, max: 100)" },
                { "key": "tag", "value": "tech", "description": "Filter by tag name", "disabled": true },
                { "key": "domain", "value": "example.com", "description": "Filter by domain", "disabled": true },
                { "key": "from", "value": "2025-01-01T00:00:00.000Z", "description": "Filter clips saved on or after (ISO 8601)", "disabled": true },
                { "key": "to", "value": "2025-12-31T23:59:59.999Z", "description": "Filter clips saved on or before (ISO 8601)", "disabled": true }
              ]
            },
            "description": "Returns the authenticated user's clips, paginated. All query parameters are optional."
          },
          "response": [
            {
              "name": "200 — Success",
              "originalRequest": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/clips?page=1&limit=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["clips"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "20" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": \"clx1clip1234abcd\",\n      \"userId\": \"clx1abc123def456\",\n      \"url\": \"https://example.com/article\",\n      \"domain\": \"example.com\",\n      \"title\": \"Interesting Article\",\n      \"description\": \"A deep dive into something fascinating\",\n      \"ogImage\": null,\n      \"faviconUrl\": null,\n      \"isPublic\": true,\n      \"savedAt\": \"2025-01-15T12:00:00.000Z\",\n      \"updatedAt\": \"2025-01-15T12:00:00.000Z\",\n      \"tags\": []\n    }\n  ],\n  \"meta\": {\n    \"page\": 1,\n    \"limit\": 20,\n    \"total\": 1,\n    \"hasMore\": false\n  }\n}"
